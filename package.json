{
  "name": "astro-blog-shokax",
  "version": "1.6.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build:site": "bunx --bun astro build",
    "build:index": "bunx --bun pagefind --site ./dist",
    "build": "bun run build:site && bun run build:index",
    "preview": "bunx --bun astro preview",
    "astro": "bunx --bun astro",
    "check": "bunx --bun astro check --root . && bunx --bun svelte-check",
    "check-links": "lychee ./dist --root-dir ./dist --offline --exclude favicon.svg --cache",
    "lint": "bunx --bun oxlint --type-aware --type-check . --fix",
    "format": "bunx oxfmt .",
    "test": "bun run test:unit",
    "test:unit": "bun test src",
    "e2e:smoke": "bunx playwright test --grep @smoke",
    "e2e:critical": "bunx playwright test --grep @critical",
    "e2e:regression": "bunx playwright test --grep @regression",
    "hyc": "hyc"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/compiler-rs": "^0.3.0",
    "@astrojs/markdown-satteri": "^0.3.3",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/svelte": "9.0.1",
    "@astrojs/ts-plugin": "1.10.10",
    "@ctrl/tinycolor": "^4.2.0",
    "@hyacine/astro": "^0.0.3",
    "@hyacine/cli": "^0.0.3",
    "@hyacine/core": "^0.0.3",
    "@hyacine/helper": "^0.0.3",
    "@hyacine/mouse-firework": "^0.0.3",
    "@hyacine/site-uptime": "^0.0.3",
    "@pagefind/component-ui": "^1.5.2",
    "@playform/inline": "^0.1.4",
    "@unocss/astro": "^66.7.4",
    "@unocss/extractor-svelte": "^66.7.4",
    "@vtbag/element-crossing": "^1.1.0",
    "@waline/client": "^3.15.2",
    "astro": "7.0.6",
    "cn-font-split": "^7.4.3",
    "echarts": "^6.1.0",
    "es-toolkit": "^1.49.0",
    "i18next": "^26.3.4",
    "katex": "^0.17.0",
    "mouse-firework": "^0.2.0",
    "node-emoji": "^2.2.0",
    "nyx-player": "^0.1.1",
    "pagefind": "^1.5.2",
    "satteri": "^0.9.4",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3",
    "vite-plugin-es-toolkit": "^1.1.0",
    "vite-plugin-font": "^5.1.2"
  },
  "devDependencies": {
    "@iconify-json/ri": "^1.2.10",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@shikijs/colorized-brackets": "^4.3.1",
    "@shikijs/transformers": "^4.3.1",
    "@types/bun": "^1.3.14",
    "@unocss/preset-attributify": "^66.7.4",
    "@unocss/preset-icons": "^66.7.4",
    "@unocss/preset-wind4": "^66.7.4",
    "@unocss/reset": "^66.7.4",
    "@unocss/transformer-directives": "^66.7.4",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "^2.10.3",
    "unocss": "^66.7.4"
  },
  "packageManager": "bun@1.3.12",
  "trustedDependencies": [
    "cn-font-split",
    "esbuild",
    "koffi",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}