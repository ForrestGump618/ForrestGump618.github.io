---
import Layout from "@/layouts/Layout.astro";
import MomentsContent from "@/components/MomentsContent.astro";
import Pagination from "@/components/Pagination.astro";
import { getCollection } from "astro:content";
import themeConfig from "@/theme.config";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allMoments = await getCollection("moments");

  const sortedMoments = allMoments.toSorted(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

  const pageSize = themeConfig.home?.pageSize ?? 10;

  // 分页生成，第一页由 index.astro 处理
  const pages = paginate(sortedMoments, { pageSize });
  return pages.filter((p) => p.params.page !== "1");
}) satisfies GetStaticPaths;

const { page } = Astro.props as {
  page: {
    data: CollectionEntry<"moments">[];
    currentPage: number;
    lastPage: number;
  };
};

const pageTitle = `动态 - 第${page.currentPage}页`;

// 分页导航
const paginationNavigation = {
  prevUrl:
    page.currentPage > 1
      ? page.currentPage === 2
        ? "/moments/"
        : `/moments/page/${page.currentPage - 1}/`
      : undefined,
  nextUrl:
    page.currentPage < page.lastPage
      ? `/moments/page/${page.currentPage + 1}/`
      : undefined,
};
---

<Layout
  pageTitle={pageTitle}
  indexPage={true}
  navigation={paginationNavigation}
>
  <Fragment slot="head">
    <meta name="description" content="动态 - 记录生活的点滴" />
  </Fragment>

  <MomentsContent moments={page.data} />
  <Pagination
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    firstPageHref="/moments/"
    routePrefix="/moments"
  />
</Layout>
