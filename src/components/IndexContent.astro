---
import type { CollectionEntry } from "astro:content";
import PostSegments from "./postSegments/PostSegments.astro";
import CategoryCards from "./categoryCard/CategoryCards.svelte";
import Divider from "./Divider.astro";
import { transformIndexPosts } from "@/toolkit/posts/transformIndexPosts";
import { covers, getPostCover } from "./Images.astro";
import { resolveHeaderCovers } from "@/toolkit/headerCover";
import { t } from "@/i18n";
import themeConfig from "@/theme.config";

interface CategoryItem {
  name: string;
  url: string;
  cover?: string;
  topCategory?: {
    name: string;
    url: string;
  };
  postCount: number;
  childCount?: number;
  posts: Array<{ title: string; url: string }>;
}

interface Props {
  posts: CollectionEntry<"posts">[];
  stickyPosts?: CollectionEntry<"posts">[];
  categories?: CategoryItem[];
  isFirstPage?: boolean;
}

const {
  posts,
  stickyPosts = [],
  categories = [],
  isFirstPage = true,
} = Astro.props;

const coverConfig = themeConfig.cover || {};
const advancedCarousel = coverConfig.advancedCarousel === true;
const headerCovers = advancedCarousel
  ? await resolveHeaderCovers({
      coverUrls: coverConfig.coverUrls,
      fallbackCovers: covers,
    })
  : [];

const hycConfig = themeConfig.hyc || {};
const aiSummaryConfig = hycConfig.aiSummary || {};
const hycEnable = hycConfig.enable === true;
const cardExcerptSource = aiSummaryConfig.cardExcerptSource ?? "default";

// 当配置为 AI 摘要来源时，批量预取列表文章的 AI 摘要；失败或缺失则回退默认摘要
const aiSummaries = new Map<string, string>();
if (hycEnable && cardExcerptSource === "ai") {
  try {
    const { getPostSummary } = await import("@hyacine/cli/api");
    const candidates = [...stickyPosts, ...posts].filter(
      (post) => !post.data.encrypted,
    );
    const entries = await Promise.all(
      candidates.map(async (post) => {
        try {
          const result = (await getPostSummary(post.id)) as {
            summary?: { content?: string | null };
          } | null;
          const content = result?.summary?.content?.trim() ?? "";
          return [post.id, content] as const;
        } catch {
          return [post.id, ""] as const;
        }
      }),
    );
    for (const [slug, content] of entries) {
      if (content) {
        aiSummaries.set(slug, content);
      }
    }
  } catch {
    // @hyacine/cli 不可用：保持空 Map，自动回退默认摘要
  }
}

const transformOptions = {
  encryptedExcerpt: t("post.encryptedExcerpt"),
  resolveCover: (post: CollectionEntry<"posts">) => getPostCover(post, headerCovers),
  excerptSource: cardExcerptSource,
  aiSummaries,
};

const transformedStickyPosts = transformIndexPosts(stickyPosts, transformOptions);
const transformedPosts = transformIndexPosts(posts, transformOptions);
---

<div class="index wrap">
  {
    isFirstPage && transformedStickyPosts.length > 0 && (
      <section class="sticky-section">
        <Divider title={t("post.sticky")} />
        <div class="segments sticky">
          <PostSegments posts={transformedStickyPosts} />
        </div>
      </section>
    )
  }

  {
    isFirstPage && categories.length > 0 && (
      <section class="categories-section">
        <Divider title={t("category.title")} />
        <div class="cards">
          <CategoryCards categories={categories} client:load />
        </div>
      </section>
    )
  }

  {
    transformedPosts.length > 0 ? (
      <section class="posts-section">
        {isFirstPage && <Divider title={t("post.latest")} />}
        <div class="segments posts">
          <PostSegments posts={transformedPosts} />
        </div>
      </section>
    ) : (
      <section class="no-posts-section">
        <div class="no-posts">
          <p>{t("post.noContent")}</p>
        </div>
      </section>
    )
  }
</div>

<style>
  .index.wrap {
    position: relative;
    padding: 1.25rem;
  }

  .sticky-section,
  .categories-section,
  .posts-section,
  .no-posts-section {
    margin-bottom: 2rem;
  }

  .sticky-section:last-child,
  .categories-section:last-child,
  .posts-section:last-child,
  .no-posts-section:last-child {
    margin-bottom: 0;
  }

  .segments {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .segments.sticky,
  .segments.posts {
    margin: 0;
    width: 100%;
  }

  .cards {
    display: flex;
    margin: 0 auto;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .no-posts {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--grey-5);
  }

  .no-posts p {
    font-size: 1.125rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .index.wrap {
      padding: 0.625rem;
    }

    .sticky-section,
    .categories-section,
    .posts-section,
    .no-posts-section {
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .index.wrap {
      padding: 0.5rem;
    }

    .sticky-section,
    .categories-section,
    .posts-section,
    .no-posts-section {
      margin-bottom: 1rem;
    }
  }
</style>
